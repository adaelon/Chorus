# 复制为 .env 并填入真实值；.env 不入库（见 .gitignore）。
# 任意兼容 OpenAI /v1 协议的后端均可。
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=kimi-k2.6
LLM_TEMPERATURE=0.75

# 可选：
# LLM_STRUCTURED_METHOD=text_json   # 结构化输出策略；默认 text_json
# LLM_MAX_TOKENS=                   # 输出上限；默认不限
# CHORUS_DOTENV=                    # 覆盖 .env 路径

# 执行层（沙箱 + MCP 工具，见 docs/启动指南.md §四）：
# CHORUS_SANDBOX_DOMAIN=127.0.0.1:8080          # OpenSandbox server host:port（不含 http://）
# CHORUS_SANDBOX_API_KEY=your-secret-api-key    # 与 sandbox.toml [server].api_key 一致
# CHORUS_SANDBOX_IMAGE=opensandbox/code-interpreter:latest  # 默认值，通常不用改
# CHORUS_EXECUTION=1                            # 仅启用 MCP（无沙箱）
